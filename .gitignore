# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native folders (managed by CNG - Continuous Native Generation)
# These folders are generated by `npx expo prebuild`
# DO NOT commit these to git - use config plugins instead
/android/
/ios/

# Native files
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# Config plugins (CNG)
plugins/build/
plugins/node_modules/

# Prebuild logs
*.log
prebuild*.log

# Phase selection (set by prebuild.js, not committed)
.phase

# Build numbers
.build-numbers.json

# iOS
ios/Pods/
ios/.xcodebuild.log
ios/build/
ios/DerivedData/
*.xcworkspace/xcuserdata
*.xcodeproj/xcuserdata
*.xcodeproj/project.xcworkspace/xcuserdata

# Android
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/.idea/
android/*.iml
*.keystore
!debug.keystore

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
Gemfile.lock
.bundle/

# Ignore source reference
_ignore/
